{
    "name": "phpframe-project/phpframe",
    "description": "A modern PHP 8.1+ framework with FPM/CLI/Shell modes support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-pdo": "*",
        "aliyuncs/oss-sdk-php": "^2.4",
        "aws/aws-sdk-php": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/cache": "^10.0",
        "illuminate/database": "^10.0",
        "illuminate/encryption": "^10.49",
        "illuminate/events": "^10.0",
        "illuminate/filesystem": "^10.0",
        "illuminate/hashing": "^10.0",
        "illuminate/pagination": "^10.0",
        "illuminate/redis": "^10.0",
        "monolog/monolog": "^3.0",
        "nikic/fast-route": "^1.3",
        "phpoption/phpoption": "^1.9",
        "predis/predis": "^2.0",
        "qcloud/cos-sdk-v5": "^2.4",
        "qiniu/php-sdk": "^7.4",
        "react/child-process": "^0.6.6",
        "react/event-loop": "^1.0",
        "react/http": "^1.0",
        "react/socket": "^1.0",
        "symfony/cache": "^6.0",
        "symfony/var-dumper": "^6.4",
        "twig/twig": "^3.0",
        "vlucas/phpdotenv": "^5.5",
        "genkgo/mail": "^2.11",
        "ymlluo/group-robot": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "PHPFrame\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
